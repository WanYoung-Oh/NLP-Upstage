# ==================================================
# WandB Configuration (Required)
# ==================================================
# Get your API key from: https://wandb.ai/authorize
WANDB_API_KEY=your-wandb-api-key-here
WANDB_ENTITY=your-wandb-username
WANDB_PROJECT=dialogue_summarization

# Optional: Disable WandB for testing
# WANDB_MODE=offline

# Optional: WandB run name prefix
# WANDB_RUN_PREFIX=exp

# ==================================================
# Data Paths (Optional - can be set in config.yaml)
# ==================================================
# DATA_PATH=./data
# OUTPUT_DIR=./outputs
# CHECKPOINT_DIR=./checkpoints

# ==================================================
# HuggingFace (Optional)
# ==================================================
# HF_TOKEN=your-huggingface-token
# HF_HOME=~/.cache/huggingface

# ==================================================
# Training Environment (Optional)
# ==================================================
# CUDA_VISIBLE_DEVICES=0,1,2,3
# TOKENIZERS_PARALLELISM=false

# ==================================================
# Python Environment (Optional)
# ==================================================
# PYTHONPATH=./src

# ==================================================
# Logging (Optional)
# ==================================================
# LOG_LEVEL=INFO
